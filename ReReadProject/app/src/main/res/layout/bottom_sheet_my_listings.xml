<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Listings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/textColor"/>

        <Button
            android:id="@+id/btn_add_listing"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="+ Add Listing"
            android:textSize="13sp"
            android:backgroundTint="#288B57"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            app:cornerRadius="20dp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_my_listings"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:id="@+id/tv_empty_listings"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚"
            android:textSize="40sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No listings yet"
            android:textSize="16sp"
            android:textColor="@color/gray_medium"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + Add Listing to get started"
            android:textSize="13sp"
            android:textColor="@color/gray_medium"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</LinearLayout>